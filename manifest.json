{
  "manifest_version": 3,
  "name": "Job Copy Extension",
  "version": "1.0.1",
  "description": "Select fields from job pages and copy them as CSV.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Copy Extension"
  },
  "options_page": "options.html",
  "commands": {
    "select-element": {
      "suggested_key": {
        "default": "Alt+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Start element selection mode"
    },
    "scrape-now": {
      "suggested_key": {
        "default": "Alt+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Scrape active list and copy CSV"
    }
  }
}